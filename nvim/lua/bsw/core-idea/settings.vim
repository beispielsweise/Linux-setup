" --- Editor Options ---
set number
set relativenumber
set tabstop=4
set shiftwidth=4
set expandtab
set smarttab
set softtabstop=4

set wrap
set ignorecase
set smartcase
set backspace=indent,eol,start

set splitright
set splitbelow

set clipboard+=unnamedplus

set cursorline
set mouse=a

let g:netrw_liststyle=3
set wildignore=8.docx,*.jpg,*.png,*.gif,*.pdf
